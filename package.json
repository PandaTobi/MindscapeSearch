{
  "name": "mindscape-ama-search",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run data:build && next build",
    "start": "npx serve@14 out",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "data:validate": "tsx pipeline/validate/index.ts",
    "data:build": "tsx pipeline/index.ts",
    "data:ingest": "tsx pipeline/ingest/index.ts"
  },
  "dependencies": {
    "next": "15.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.3"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.21",
    "eslint": "9.25.1",
    "eslint-config-next": "15.2.4",
    "jsdom": "26.0.0",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "0.6.11",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.3",
    "typescript": "5.8.3",
    "vitest": "3.1.2"
  }
}
